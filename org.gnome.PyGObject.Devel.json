{
  "app-id": "org.gnome.PyGObject.Devel",
  "runtime": "org.gnome.Sdk",
  "runtime-version": "master",
  "sdk": "org.gnome.Sdk",
  "build-options": {
    "build-args": [
      "--share=network",
      "--filesystem=host"
    ],
    "test-args": [
      "--socket=session-bus",
      "--socket=fallback-x11",
      "--filesystem=host",
      "--share=network"
    ],
    "env": {
      "PYTEST_ADDOPTS": "-vs"
    }
  },
  "modules": [
    {
      "name": "dependencies",
      "buildsystem": "simple",
      "build-commands": [
        "python3 --version",
        "pip3 install --prefix=${FLATPAK_DEST} pycairo pytest pytest-cov"
      ]
    },
    {
      "name": "pygobject",
      "buildsystem": "meson",
      "builddir": true,
      "config-opts": [
        "--errorlogs",
        "-Dtests=true"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ],
      "run-tests": true
    }
  ]
}

